# VAE Guardrail Configuration
# Copy this file to .env and adjust values

# Model & Checkpoint
MODEL_NAME=distilbert-base-uncased
CHECKPOINT_PATH=./checkpoints/vae_guardrail_best.pt
CALIBRATION_PATH=./checkpoints/calibration_stats.json

# Device
DEVICE=auto  # auto | cuda | cpu

# Anomaly Thresholds
VAE_ANOMALY_THRESHOLD=1.24
VECTOR_SIMILARITY_THRESHOLD=0.85
MAX_PROMPT_LENGTH=2048

# Operational Mode
SHADOW_MODE=true  # true = log only, false = enforce blocks
LOG_LEVEL=INFO

# API Server
API_HOST=0.0.0.0
API_PORT=8080
API_WORKERS=1
